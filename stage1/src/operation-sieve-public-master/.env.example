# Stage1 LLM 增强 ANI 分析 - 环境配置模板
# 使用方法: cp .env.example .env && 填入实际值
#
# LLM_API_KEY: OpenAI 兼容 API 的 key（如 Anthropic 中转、OpenAI、laozhang.ai 等）
# LLM_API_BASE: API 基地址
# LLM_MODEL:    模型名
# GHIDRA_HOME:  可选，Ghidra 安装路径（某些分析流程需要）

LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.example.com/v1
LLM_MODEL=gpt-4

GHIDRA_HOME=/path/to/ghidra
