# FirmSieve Docker Compose 环境变量模板
# 使用方法: cp .env.example .env  然后按下面提示填值

# ============ Stage 1 LLM 配置 ============
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.example.com/v1
LLM_MODEL=gpt-4

# ============ Stage 2 LLM 配置 ============
# 可以与 Stage 1 用同一个 key/base；若想分离不同模型（分析 vs 工具）可分开设置
CLAUDE_BASE_URL=https://api.example.com/v1
CLAUDE_ANALYSIS_API_KEY=your-analysis-api-key
CLAUDE_ANALYSIS_MODEL=gpt-4
CLAUDE_TOOL_API_KEY=your-tool-api-key
CLAUDE_TOOL_MODEL=gpt-4

# ============ IDA Pro 路径（宿主机绝对路径）============
# 必填。该目录必须包含 ida 可执行文件和有效的 idapro.hexlic
IDA_HOST_PATH=/home/you/IDApro/idapro-9.0

# ============ 固件目录（容器内路径）============
# /data/firm 是 bind mount 固定挂载点（对应 stage1/firm/）
# 下面配置的是要分析的具体固件 squashfs-root 子路径
FIRMSIEVE_FIRMWARE_ROOT=/data/firm/Tenda/analyzed/_YOUR_FIRMWARE.extracted/squashfs-root

# ============ 文件权限 ============
# 使容器内进程写出的文件在宿主机上归你所有
# 用 `id -u` 和 `id -g` 查询
UID=1000
GID=1000
